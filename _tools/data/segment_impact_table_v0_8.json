{
  "_comment": "L3 v0.8 — Channel Decomposition. Шок раскладывается на 5 каналов (consumer/oil_revenue/fiscal/fx/supply_chain), каждый сегмент имеет карту чувствительности. ΔPD = Σ_каналов [sensitivity × intensity × direction × baseline] × kc_amp. Решает проблему бифуркации (один шок ↑ для одних сегментов, ↓ для других).",
  "_version": "0.8",
  "_last_updated": "2026-05-06",
  "confidence_default": "low",
  "_confidence_note": "S3.5: confidence — поле данных, а не литерал в коде. 'low' = экспертные оценки, НЕ калиброваны на реальных PD-данных банка. Поднимать до 'medium'/'high' только после бэк-теста на исторических данных (Фаза 3+).",
  "_units": {
    "delta_pd": "процентные пункты к 12М PD сегмента",
    "delta_demand": "процентное изменение спроса на кредиты",
    "delta_churn": "процентные пункты к месячному оттоку",
    "intensity": "0..1 — сила канала на единицу шока",
    "direction": "+1 (ухудшение) или -1 (улучшение)",
    "sensitivity": "0..1 — чувствительность сегмента к каналу"
  },

  "kc_regimes": {
    "normal": {"range_pct": "≤10", "amplifier": 1.0,
               "comment": "Норма: 2017-2021, июль 2022 - середина 2023"},
    "moderate_stress": {"range_pct": "10-18", "amplifier": 1.5,
                        "comment": "Умеренный стресс: 2014-2016, авг 2023 - окт 2024"},
    "acute_stress": {"range_pct": ">18", "amplifier": 2.2,
                     "comment": "Острый стресс: 02.2022-06.2022, 12.2024 - н.в."}
  },

