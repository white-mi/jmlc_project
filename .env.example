# Скопируй в .env и заполни значения. Файл .env — в .gitignore, НЕ коммить.

# Ключ Anthropic для реального L0 (5-агентный конвейер) и LangChain-агента.
# Не нужен для тестов, smoke-прогона и dry-run/fixture-режима.
ANTHROPIC_API_KEY=

# RAG-эмбеддер: 0 = TF-IDF (по умолчанию, офлайн), 1 = sentence-transformers e5-small (тянет модель).
RADAR_RAG_USE_ST=0
